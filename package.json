{
  "name": "learnvis",
  "version": "3.0.0",
  "description": "D3 visualization primitives + agent-friendly API for algorithm lessons",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown -w",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:cli": "npx tsdown cli.ts --format esm --outDir dist --clean false --minify false",
    "dev:components": "tsdown && tsdown -w & vite",
    "setup": "node scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "jsdom": "^29.1.1",
    "tsdown": "latest",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "d3": "^7.9.0",
    "d3-interpolate": "^3.0.1",
    "d3-shape": "^3.2.0"
  },
  "main": "dist/learnvis.mjs",
  "module": "dist/learnvis.mjs",
  "exports": {
    ".": {
      "import": "./dist/learnvis.mjs",
      "types": "./vis/index.ts"
    }
  }
}

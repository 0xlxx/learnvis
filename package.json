{
  "name": "learnvis",
  "version": "4.0.0",
  "description": "D3 visualization primitives + agent-friendly API for algorithm lessons",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "vite",
    "dev:lib": "tsdown -w",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:cli": "npx tsdown cli.ts --format esm --outDir dist --clean false --minify false",
    "setup": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "d3": "^7.9.0",
    "d3-interpolate": "^3.0.1",
    "d3-shape": "^3.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@learnvis/ecs": "workspace:*",
    "@learnvis/vis2d": "workspace:*",
    "@learnvis/vis3d": "workspace:*",
    "@types/d3": "^7.4.3",
    "@types/three": "^0.184.1",
    "jsdom": "^29.1.1",
    "tsdown": "latest",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "main": "dist/learnvis.mjs",
  "module": "dist/learnvis.mjs"
}

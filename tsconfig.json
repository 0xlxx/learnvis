{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "ESNext.Disposable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowUmdGlobalAccess": true,
    "types": ["d3"]
  },
  "include": ["vis/**/*.ts"]
}

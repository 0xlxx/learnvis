{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "ESNext.Disposable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowUmdGlobalAccess": true,
    "paths": {
      "@learnvis/ecs": ["./packages/ecs/src/index.ts"]
    },
    "types": ["d3"]
  },
  "include": ["vis/**/*.ts", "vis3d/**/*.ts", "packages/**/*.ts"]
}
